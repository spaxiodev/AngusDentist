# Server (local dev only)
PORT=3000

# Database (Turso)
# Local dev:  file:data/clinic.db
# Production: libsql://your-db-name.turso.io
TURSO_DATABASE_URL=file:data/clinic.db
TURSO_AUTH_TOKEN=

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email (Nodemailer) — set these to receive form submissions by email
# For Gmail: use an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFICATION_EMAIL=clinique.angus@outlook.com
FROM_EMAIL=noreply@cliniqueangus.com
